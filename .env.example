# Clés Supabase (Service Role requis pour contourner RLS côté serveur)
NEXT_PUBLIC_SUPABASE_URL="https://votre-projet.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="votre_cle_service_role"

# Clé de chiffrement AES-256-GCM (Chaîne hexadécimale de 64 caractères / 32 octets)
# Générez une clé via : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_ENCRYPTION_KEY="votre_cle_de_chiffrement_hex"

# Identifiants de l'application X (Twitter) OAuth 2.0
# Obtenus sur le portail développeur X (https://developer.x.com) 
# Callback URI configuré sur : http://127.0.0.1:3000/api/x/callback
X_CLIENT_ID=""
X_CLIENT_SECRET=""
